{
  "manifest_version": 3,
  "name": "Smart YouTube Feed",
  "description": "Filter Youtube reccomendations for productive / educational content",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "smart-youtube-feed@localhost"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": ["*://*.youtube.com/*"],
  "permissions": ["storage"],
  "action": {
    "default_popup": "dist/options.html",
    "default_title": "Smart YouTube Feed",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "js": ["dist/content.js"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
